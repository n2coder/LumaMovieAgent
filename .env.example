APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_API_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
MAX_QUERY_CHARS=500
MAX_AUDIO_BYTES=10485760
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_RECOMMEND_PER_WINDOW=30
RATE_LIMIT_VOICE_PER_WINDOW=20
RATE_LIMIT_SESSION_START_PER_WINDOW=20
SESSION_JWT_SECRET=change-me-please
SESSION_TTL_MINUTES=60
SESSION_MAX_MESSAGES=4

USE_FINE_TUNED=False

OPENAI_API_KEY=your_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=1.3
OPENAI_TTS_INSTRUCTIONS=Speak in clear Indian English with a warm, natural, conversational tone.
STT_PROVIDER=openai
DEEPGRAM_API_KEY=

FINE_TUNED_ENDPOINT=
FINE_TUNED_API_KEY=
REQUEST_TIMEOUT_SEC=45

TOP_K=5
USE_VECTOR_RETRIEVER=True
ENABLE_WEBRTC_AUDIO=True
ENABLE_WEBRTC_UPLINK=False
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_ENABLED=False
PARTIAL_STT_ENABLED=False
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

MOVIES_CSV=app/data/clean_tmdb_with_posters.csv
CREDITS_CSV=app/data/tmdb_5000_credits.csv
